# このファイルを .env にコピーして値を設定してください。
# .env は絶対にコミット・アップロードしないこと(.gitignore済み)。

# X (Twitter) API — https://developer.x.com/ で取得
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# 収集対象のXユーザー名(@なし、カンマ区切り)
X_TARGET_USERNAMES=example_user1,example_user2

# Claude API — https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=
# 任意: 使用モデルを上書きする場合のみ指定(未指定時は claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8
